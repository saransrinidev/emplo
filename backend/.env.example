# Supabase: Project Settings > Database > Connection string > "Session pooler".
# Important for this project / network:
#   - Use the Session pooler host (IPv4). The direct "db.<ref>.supabase.co" host
#     is IPv6-only and will fail with "getaddrinfo failed" on IPv4-only networks.
#   - Newer projects use the "aws-1-<region>" host prefix (not "aws-0").
#   - Change the URI prefix "postgresql://" to "postgresql+psycopg://".
#   - URL-encode special characters in the password (e.g. "$" -> "%24").
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<encoded-password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# "require" for Supabase, "disable" for local Postgres.
DB_SSL_MODE=require

JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
