# Database connection string.
# Supabase: copy from Project Settings > Database > Connection string (URI).
# Use the "Session" / direct connection (port 5432) for migrations.
# Example (Supabase): postgresql+psycopg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Example (local):    postgresql+psycopg://postgres:postgres@localhost:5432/hr_portal
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/hr_portal

# Set to "require" for Supabase, leave empty/"" or "disable" for local Postgres.
DB_SSL_MODE=disable

# JWT settings
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
